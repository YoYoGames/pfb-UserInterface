  "properties":[
    {"$GMObjectProperty":"v2","%Name":"sprite_colour","filters":[],"listItems":[],"multiselect":false,"name":"sprite_colour","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"$FFFFFFFF","varDescription":"The colour that the textbox sprite should be. This value will be used at runtime and will replace any value that was set for 'colour' in the section above.","varFriendlyName":"Sprite Colour","varType":7,},
    {"$GMObjectProperty":"v2","%Name":"font","filters":[
        "GMFont",
      ],"listItems":[],"multiselect":false,"name":"font","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resource":{"name":"fUI","path":"fonts/fUI/fUI.yy",},"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"fUI","varDescription":"The font that the text will use","varFriendlyName":"Font","varType":5,},
    {"$GMObjectProperty":"v2","%Name":"text_size","filters":[],"listItems":[],"multiselect":false,"name":"text_size","rangeEnabled":true,"rangeMax":100.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"16","varDescription":"The size the text will be (in pixels)","varFriendlyName":"Text Size","varType":1,},
    {"$GMObjectProperty":"v2","%Name":"text_colour","filters":[],"listItems":[],"multiselect":false,"name":"text_colour","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"$FF000000","varDescription":"The colour the text will be","varFriendlyName":"Text Colour","varType":7,},
    {"$GMObjectProperty":"v2","%Name":"vertical_padding","filters":[],"listItems":[],"multiselect":false,"name":"vertical_padding","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"6","varDescription":"The number of pixel in from the top and bottom that the text can be displayed","varFriendlyName":"Vertical Padding","varType":1,},
    {"$GMObjectProperty":"v2","%Name":"horizontal_padding","filters":[],"listItems":[],"multiselect":false,"name":"horizontal_padding","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"10","varDescription":"The number of pixel in from the left and right that the text can be displayed","varFriendlyName":"Horizontal Padding","varType":1,},
    {"$GMObjectProperty":"v2","%Name":"vertical_align","filters":[],"listItems":[
        "fa_top",
        "fa_middle",
        "fa_bottom",
      ],"multiselect":false,"name":"vertical_align","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"fa_middle","varDescription":"The justification of the text within the textbox; should it align to the top, middle, or bottom of the box","varFriendlyName":"Vertical Alignment","varType":6,},
    {"$GMObjectProperty":"v2","%Name":"horizontal_align","filters":[],"listItems":[
        "fa_left",
        "fa_center",
        "fa_right",
      ],"multiselect":false,"name":"horizontal_align","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"fa_center","varDescription":"The justification of the text within the textbox; should it align to the left, center, or right of the box","varFriendlyName":"Horizontal Align","varType":6,},
    {"$GMObjectProperty":"v2","%Name":"highlight_colour","filters":[],"listItems":[],"multiselect":false,"name":"highlight_colour","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"$80FBE4AE","varDescription":"The colour the textbox should be when the user has clicked onto it. This can also include an alpha value (how transparent it is) so you can set the alpha part of the colour to 255 to fully replace the colour of the sprite, or set it to a lower value to mix your highlight colour with the sprite_colour value","varFriendlyName":"Highlight Colour","varType":7,},
    {"$GMObjectProperty":"v2","%Name":"caret_visible","filters":[],"listItems":[],"multiselect":false,"name":"caret_visible","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"True","varDescription":"Should a vertical line ( | )  be shown at the end of the text to show that the text is being edited","varFriendlyName":"Show Caret","varType":3,},
    {"$GMObjectProperty":"v2","%Name":"overflow_behaviour","filters":[],"listItems":[
        "\"scroll\"",
        "\"wrap\"",
      ],"multiselect":false,"name":"overflow_behaviour","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"\"wrap\"","varDescription":"If the text that is in the textbox is longer than the width of the text box, should the text keep going on the same line (\"scroll\") or should it continue on the next line (\"wrap\")","varFriendlyName":"Overflow Behaviour","varType":6,},
    {"$GMObjectProperty":"v2","%Name":"expected_input","filters":[],"listItems":[
        "\"all\"",
        "\"int\"",
        "\"real\"",
      ],"multiselect":false,"name":"expected_input","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"\"all\"","varDescription":"What type of value are you expecting to be entered into the text box?\r\nall: Any keyboard character will be added to the displayed string\r\nint: Only digits will be added, so the result will be an integer (leading zeros are accepted)\r\nreal: Only digits, the first character being a minus sign, and a single decimal point will be added","varFriendlyName":"Expected Input","varType":6,},
    {"$GMObjectProperty":"v2","%Name":"line_separation","filters":[],"listItems":[],"multiselect":false,"name":"line_separation","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"0","varDescription":"Number of pixels of a gap that will be present between lines of text. This requires \"wrap\" overflow_behaviour for this to be seen","varFriendlyName":"Line Separation","varType":1,},
    {"$GMObjectProperty":"v2","%Name":"editable","filters":[],"listItems":[],"multiselect":false,"name":"editable","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"true","varDescription":"Can the user edit the text when the game is run? Setting this to false will prevent the text being changed by the user but it can still be changed through code at runtime","varFriendlyName":"Editable","varType":3,},
    {"$GMObjectProperty":"v2","%Name":"interaction_end_function","filters":[],"listItems":[],"multiselect":false,"name":"interaction_end_function","rangeEnabled":false,"rangeMax":10.0,"rangeMin":0.0,"resourceType":"GMObjectProperty","resourceVersion":"2.0","value":"undefined","varDescription":"Optional function that should be called when the interaction with the textbox ends (losing focus or user pressing Enter)","varFriendlyName":"Interaction End Function","varType":4,},
